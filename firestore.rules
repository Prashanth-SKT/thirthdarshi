rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper checks ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Matches admin email in App.js and LoginScreen.js (admin@temple.com)
    // You must sign in with this exact Firebase account to edit temple data.
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() == 'admin@temple.com';
    }

    // --- Temple app data (Android app uses these) ---
    match /temples/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /temple_details/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /search_tags/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /temple_sevas/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /temple_timings/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /app_config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- User profile (SignUpScreen writes here) ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/favorites/{docId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/bookmarks/{docId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Reviews ---
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // --- Feedback: users can submit, only admin can read/delete ---
    match /feedback/{docId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // --- Blogs: logged-in users read, only admin writes ---
    match /blogs/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // IMPORTANT: No catch-all rule at the end.
    // Anything not listed above is BLOCKED.
  }
}
