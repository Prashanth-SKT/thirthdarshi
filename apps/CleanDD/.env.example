# Copy to .env for local development (never commit .env with real values).
# Android Maps key — also set in android/gradle.properties as MAPS_API_KEY
MAPS_API_KEY=your_google_maps_api_key

# Google Directions / Places (packages/google/googleApi.js)
GOOGLE_API_KEY=your_google_api_key

# Firebase — config is in firebase.config.js and google-services.json
# Restrict all keys to com.thirtdarshi.app in Google Cloud Console.

# Release signing — android/keystore.properties (gitignored, not .env)
# RELEASE_STORE_FILE=app/thirtdarshi-new.keystore
# RELEASE_STORE_PASSWORD=
# RELEASE_KEY_ALIAS=thirtdarshi
# RELEASE_KEY_PASSWORD=
